{
    "name": "gitlab-mr-ui",
    "displayName": "Gitlab MR UI",
    "description": "Quick create merge request with UI",
    "version": "2.3.1",
    "publisher": "Dezmont51",
    "repository": {
        "type": "git",
        "url": "https://github.com/Dezmont51/vscode-gitlab-mr"
    },
    "icon": "img/gitlab-logo.png",
    "engines": {
        "vscode": "^1.96.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "extension.openMR",
                "title": "Gitlab MR: Create MR",
                "icon": "$(git-pull-request)"
            },
            {
                "command": "extension.viewMR",
                "title": "Gitlab MR: View MR"
            },
            {
                "command": "extension.checkoutMR",
                "title": "Gitlab MR: Checkout MR"
            },
            {
                "command": "extension.editMR",
                "title": "Gitlab MR: Edit MR"
            }
        ],
        "keybindings": [
            {
                "command": "extension.openMR",
                "key": "ctrl+k ctrl+m",
                "mac": "cmd+k cmd+m",
                "when": "editorTextFocus"
            },
            {
                "command": "extension.viewMR",
                "key": "ctrl+k ctrl+v",
                "mac": "cmd+k cmd+v",
                "when": "editorTextFocus"
            },
            {
                "command": "extension.checkoutMR",
                "key": "ctrl+k ctrl+b",
                "mac": "cmd+k cmd+b",
                "when": "editorTextFocus"
            }
        ],
        "menus": {
            "scm/title": [
                {
                    "command": "extension.openMR",
                    "when": "scmProvider == 'git'",
                    "group": "navigation"
                }
            ]
        },
        "configuration": {
            "title": "Gitlab MR",
            "properties": {
                "gitlab-mr.accessTokens": {
                    "type": "object",
                    "default": "{}",
                    "description": "Key/value pairs of Gitlab Server URLs and Gitlab Access Tokens."
                },
                "gitlab-mr.accessToken": {
                    "type": "string",
                    "default": null,
                    "description": "Gitlab Access Token for https://gitlab.com. Use gitlab-mr.accessTokens for CE/EE servers."
                },
                "gitlab-mr.targetBranch": {
                    "type": "string",
                    "default": "master",
                    "description": "Target branch for MRs."
                },
                "gitlab-mr.targetRemote": {
                    "type": "string",
                    "default": "origin",
                    "description": "Git remote to push to."
                },
                "gitlab-mr.autoOpenMr": {
                    "type": "boolean",
                    "default": false,
                    "description": "Open newly created MRs in your browser."
                },
                "gitlab-mr.removeSourceBranch": {
                    "type": "boolean",
                    "default": false,
                    "description": "When creating MRs, enable the option to remove the source branch after merging."
                },
                "gitlab-mr.useDefaultBranch": {
                    "type": "boolean",
                    "default": false,
                    "description": "When creating MRs, use default_branch set in repository as target branch."
                },
                "gitlab-mr.apiVersion": {
                    "type": "string",
                    "default": "v4",
                    "description": "Gitlab API version, e.g. v4."
                },
                "gitlab-mr.openToEdit": {
                    "type": "boolean",
                    "default": false,
                    "description": "Open and edit newly created MRs in your browser."
                },
                "gitlab-mr.projectLabels": {
                    "type": "array",
                    "default": [],
                    "description": "Stored labels for the project."
                }
            }
        }
    },
    "scripts": {
        "lint": "eslint .",
        "test": "mocha",
        "compile": "npm run copy-templates && node esbuild.js",
        "watch": "npm-run-all -p watch:*",
        "watch:esbuild": "node esbuild.js --watch",
        "vscode:prepublish": "npm run package",
        "package": "npm run copy-templates && node esbuild.js --production",
        "package-vsix": "vsce package -o ./bin/vscode-gitlab-mr.vsix --baseContentUrl https://github.com/Dezmont51/vscode-gitlab-mr/tree/main --baseImagesUrl https://raw.githubusercontent.com/Dezmont51/vscode-gitlab-mr/main",
        "copy-templates": "cpx \"src/templates/**/*\" \"dist/templates\""
    },
    "pre-commit": [
        "compile",
        "test"
    ],
    "devDependencies": {
        "mocha": "^11.2.0",
        "chai": "^3.5.0",
        "cpx": "^1.5.0",
        "esbuild": "^0.23.1",
        "eslint": "^9.28.0",
        "@eslint/js": "^9.4.0",
        "npm-run-all": "^4.1.5",
        "@vscode/vsce": "^3.3.2",
        "@vscode/test-electron": "^2.5.2",
        "pre-commit": "^1.2.2"
    },
    "dependencies": {
        "axios": "^1.4.0",
        "ejs": "^3.1.7",
        "lodash.trimstart": "^4.5.1",
        "opn": "^4.0.2",
        "simple-git": "^3.26.0",
        "ssh-parse": "^1.0.0"
    }
}
